{
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noUselessConstructor": "off"
      },
      "correctness": {
        "noUnusedFunctionParameters": "off"
      },
      "style": {
        "useExponentiationOperator": "off"
      },
      "suspicious": {
        "noAssignInExpressions": "off",
        "noPrototypeBuiltins": "off"
      }
    }
  }
}
